tical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>members</th>\n    </tr>\n    <tr>\n      <th>community</th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>Honda Cars, Stellantis, Mercedes-Benz, Volvo, ...</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>Maruti Suzuki, Nissan, HP, NL, LD, KL, AS, ML,...</td>\n    </tr>\n    <tr>\n      <th>2</th>\n      <td>Tata Motors, Mahindra, RJ, OD, BR, UK, JH, SK,...</td>\n    </tr>\n  </tbody>\n</table>\n</div>\n```\n:::\n:::\n\n\n## State similarity space\n\n::: {#ff262ae9 .cell execution_count=5}\n``` {.python .cell-code}\nsim = nb.state_similarity_graph(edges[edges.year == LATEST_FULL], min_similarity=0.85)\nsim_comm = nm.communities(sim)\nsim_comm.reset_index().groupby(\"community\")[\"node\"].apply(lambda s: \", \".join(sorted(s))).to_frame(\"states\")\n```\n\n::: {.cell-output .cell-output-display execution_count=5}\n```{=html}\n<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>states</th>\n    </tr>\n    <tr>\n      <th>community</th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>AN, AP, AR, BR, CG, CH, DL, DN, GJ, HR, JH, KA...</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>AS, GA, HP, JK, KL, LA, LD, ML, MN, MZ, NL, TR</td>\n    </tr>\n  </tbody>\n</table>\n</div>\n```\n:::\n:::\n\n\n## Finding\n\nThe network stayed dense through BS6 and COVID — shocks moved volumes, not\nthe OEM–state participation structure. Modularity is low (≈0.1): India's PV\nmarket is one national community with Maruti/Hyundai/Tata as hubs rather than\na set of regional clusters; what regional texture exists shows up in the state\n*similarity* graph, where CNG-heavy northern/western states cluster apart from\nthe diesel-leaning south and the EV-forward early-adopter states. Export the\nGEXF artifacts (`uv run lab run oem-state-network`) for Gephi/ForceAtlas2 views.\n\n",
