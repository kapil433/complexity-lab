 gd.closest('#notebook-container');\nif (notebookContainer) {{\n    x.observe(notebookContainer, {childList: true});\n}}\n\n// Listen for the clearing of the current output cell\nvar outputEl = gd.closest('.output');\nif (outputEl) {{\n    x.observe(outputEl, {childList: true});\n}}\n\n                        })                };            </script>        </div>\n```\n:::\n:::\n\n\n## Finding\n\nEV adoption in most large states fits Bass dynamics well (R² > 0.95 on\ncumulative curves), with imitation (q) dominating innovation (p) — adoption is\ncontagion-led, not advertising-led. With the audited real-income measure,\ncross-state q has a weak negative rank correlation (about -0.24), so richer\nstates do not mechanically imitate faster in this sample. Charger counts remain\nan incomplete 2025 snapshot and broad credit is not vehicle finance; these\ncross-sectional relationships are descriptive, not annual treatment effects.\n\n",
