n      <td id=\"T_6f7b2_row8_col1\" class=\"data row8 col1\" >0.0734</td>\n      <td id=\"T_6f7b2_row8_col2\" class=\"data row8 col2\" >2.872e+04</td>\n      <td id=\"T_6f7b2_row8_col3\" class=\"data row8 col3\" >0.9987</td>\n      <td id=\"T_6f7b2_row8_col4\" class=\"data row8 col4\" >64.71</td>\n    </tr>\n    <tr>\n      <th id=\"T_6f7b2_level0_row9\" class=\"row_heading level0 row9\" >WB</th>\n      <td id=\"T_6f7b2_row9_col0\" class=\"data row9 col0\" >3.334e-05</td>\n      <td id=\"T_6f7b2_row9_col1\" class=\"data row9 col1\" >0.07233</td>\n      <td id=\"T_6f7b2_row9_col2\" class=\"data row9 col2\" >2.777e+04</td>\n      <td id=\"T_6f7b2_row9_col3\" class=\"data row9 col3\" >0.9984</td>\n      <td id=\"T_6f7b2_row9_col4\" class=\"data row9 col4\" >106.2</td>\n    </tr>\n    <tr>\n      <th id=\"T_6f7b2_level0_row10\" class=\"row_heading level0 row10\" >RJ</th>\n      <td id=\"T_6f7b2_row10_col0\" class=\"data row10 col0\" >0.0004495</td>\n      <td id=\"T_6f7b2_row10_col1\" class=\"data row10 col1\" >0.07225</td>\n      <td id=\"T_6f7b2_row10_col2\" class=\"data row10 col2\" >5.114e+04</td>\n      <td id=\"T_6f7b2_row10_col3\" class=\"data row10 col3\" >0.9951</td>\n      <td id=\"T_6f7b2_row10_col4\" class=\"data row10 col4\" >69.87</td>\n    </tr>\n    <tr>\n      <th id=\"T_6f7b2_level0_row11\" class=\"row_heading level0 row11\" >KL</th>\n      <td id=\"T_6f7b2_row11_col0\" class=\"data row11 col0\" >2.897e-05</td>\n      <td id=\"T_6f7b2_row11_col1\" class=\"data row11 col1\" >0.07205</td>\n      <td id=\"T_6f7b2_row11_col2\" class=\"data row11 col2\" >8.436e+04</td>\n      <td id=\"T_6f7b2_row11_col3\" class=\"data row11 col3\" >0.9975</td>\n      <td id=\"T_6f7b2_row11_col4\" class=\"data row11 col4\" >108.5</td>\n    </tr>\n    <tr>\n      <th id=\"T_6f7b2_level0_row12\" class=\"row_heading level0 row12\" >GJ</th>\n      <td id=\"T_6f7b2_row12_col0\" class=\"data row12 col0\" >0.0002729</td>\n      <td id=\"T_6f7b2_row12_col1\" class=\"data row12 col1\